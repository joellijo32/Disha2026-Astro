---
import '../index.css';
import EasterEggVIP from '../components/EasterEggVIP.tsx';
import eventsBg from '../assets/events_background.webp';
import kalyaniBg from '../assets/kalyani_background_2.webp';
import dishaLogo from '../assets/disha_logo.webp';
import bohmeFont from '../assets/fonts/bohme/Bohme.ttf';
import myriadRegular from '../assets/fonts/myriad-pro/MYRIADPRO-REGULAR.OTF';
import myriadBold from '../assets/fonts/myriad-pro/MYRIADPRO-BOLD.OTF';
import myriadSemibold from '../assets/fonts/myriad-pro/MYRIADPRO-SEMIBOLD.OTF';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <link rel="icon" type="image/webp" href="/favicon.webp" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="image" href={kalyaniBg.src} />
    <link rel="preload" as="font" href="https://fonts.gstatic.com/s/sedgwickavedisplay/v23/xfuu0XPgU3jZPUoUo3ScvmPi-NapQ8OxM1c0fec.woff2" crossorigin type="font/woff2" />
    <link rel="preload" as="font" href={bohmeFont} crossorigin type="font/ttf" />
    <link rel="preload" as="font" href={myriadRegular} crossorigin type="font/otf" />
    <link rel="preload" as="font" href={myriadBold} crossorigin type="font/otf" />
    <link rel="preload" as="font" href={myriadSemibold} crossorigin type="font/otf" />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Anton&family=Anton+SC&display=swap" />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Radio+Canada+Big:ital,wght@0,400..700;1,400..700&display=swap" />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Sedgwick+Ave&family=Sedgwick+Ave+Display&display=swap" />
    <link href="https://fonts.googleapis.com/css2?family=Anton&family=Anton+SC&display=swap" rel="stylesheet" media="print" onload="this.media='all'" />
    <link href="https://fonts.googleapis.com/css2?family=Radio+Canada+Big:ital,wght@0,400..700;1,400..700&display=swap" rel="stylesheet" media="print" onload="this.media='all'" />
    <link href="https://fonts.googleapis.com/css2?family=Sedgwick+Ave&family=Sedgwick+Ave+Display&display=swap" rel="stylesheet" media="print" onload="this.media='all'" />
    <noscript>
      <link href="https://fonts.googleapis.com/css2?family=Anton&family=Anton+SC&display=swap" rel="stylesheet" />
      <link href="https://fonts.googleapis.com/css2?family=Radio+Canada+Big:ital,wght@0,400..700;1,400..700&display=swap" rel="stylesheet" />
      <link href="https://fonts.googleapis.com/css2?family=Sedgwick+Ave&family=Sedgwick+Ave+Display&display=swap" rel="stylesheet" />
    </noscript>
    <meta name="description" content="College departments compete for a cup through performances and competitions over several days." />
    <title>Disha '26</title>
  </head>
  <body class="bg-black overflow-hidden">
    <div id="splash-screen" class="fixed inset-0 z-[9999] flex flex-col items-center justify-center bg-[#050505] transition-opacity duration-700">
      <div class="flex flex-col items-center splash-content">
        <div class="w-48 h-[2px] bg-white/10 rounded-full overflow-hidden">
          <div id="splash-progress" class="w-full h-full bg-[#DE005F] transition-transform duration-500 ease-out origin-left" style="transform: scaleX(0);"></div>
        </div>
        <p class="mt-4 text-white/40 text-[10px] tracking-[0.3em] font-bohme uppercase">Disha '26</p>
      </div>
    </div>

    <div id="page-freeze-zone">
      <slot />
    </div>
    <EasterEggVIP client:idle imageUrls={[eventsBg.src, kalyaniBg.src]} />
  </body>
</html>

<style is:global>
  /* Hide scrollbar for Chrome, Safari and Opera */
  html::-webkit-scrollbar,
  body::-webkit-scrollbar {
    display: none;
  }
  /* Hide scrollbar for IE, Edge and Firefox */
  html,
  body {
    -ms-overflow-style: none;  /* IE and Edge */
    scrollbar-width: none;  /* Firefox */
  }

  .custom-scrollbar::-webkit-scrollbar {
    width: 6px;
  }
  .custom-scrollbar::-webkit-scrollbar-track {
    background: rgba(255, 255, 255, 0.05);
    border-radius: 8px;
    margin-block: 10px;
  }
  .custom-scrollbar::-webkit-scrollbar-thumb {
    background: rgba(222, 0, 95, 0.7);
    border-radius: 8px;
  }
  .custom-scrollbar::-webkit-scrollbar-thumb:hover {
    background: rgba(222, 0, 95, 1);
  }

  @keyframes splashFadeIn {
    from { opacity: 0; transform: scale(0.95); }
    to { opacity: 1; transform: scale(1); }
  }

  .splash-content {
    animation: splashFadeIn 1s ease-out forwards;
  }
</style>
<script is:inline>
  // Use is:inline to ensure it runs as early as possible and doesn't get bundled in a way that delays execution
  (function() {
    const splash = document.getElementById('splash-screen');
    const progress = document.getElementById('splash-progress');
    const content = document.getElementById('page-freeze-zone');
    const body = document.body;

    if (!splash || !progress || !content) return;

    // Initial progress boost
    setTimeout(() => {
      progress.style.transform = 'scaleX(0.3)';
    }, 100);

    let isLoaded = false;
    let fontsLoaded = false;

    function checkReady() {
      if (isLoaded && fontsLoaded) {
        progress.style.transform = 'scaleX(1)';
        
        setTimeout(() => {
          splash.style.opacity = '0';
          body.classList.remove('overflow-hidden');
          
            setTimeout(() => {
            splash.style.visibility = 'hidden';
            window.__siteReady = true;
            window.dispatchEvent(new CustomEvent('site-ready'));
            }, 700);
        }, 500);
      }
    }

    document.addEventListener('DOMContentLoaded', () => {
      isLoaded = true;
      progress.style.transform = 'scaleX(0.7)';
      checkReady();
    });

    // Handle fonts
    if (document.fonts) {
      document.fonts.ready.then(() => {
        fontsLoaded = true;
        checkReady();
      });
    } else {
      fontsLoaded = true; // Fallback for older browsers
      checkReady();
    }

    // Safety timeout - don't stay on splash forever if something hangs
    setTimeout(() => {
      if (!isLoaded || !fontsLoaded) {
        isLoaded = true;
        fontsLoaded = true;
        checkReady();
      }
    }, 5000);
  })();
</script>
