<div
  id="vip-wrapper"
  class="fixed inset-0 z-[100] hidden opacity-0 transition-opacity duration-500 ease-in-out"
>
  <!-- Layer 1: The Environment (Backdrop) -->
  <div id="vip-backdrop" class="absolute inset-0 bg-[#050505] cursor-pointer">
    <canvas id="vip-canvas" class="absolute inset-0 w-full h-full pointer-events-none"></canvas>
  </div>

  <!-- Dim Overlay: lights out during transition -->
  <div id="vip-dim" class="absolute inset-0 bg-[#000000] opacity-0 pointer-events-none transition-opacity duration-700 ease-in-out"></div>

  <!-- Layer 2: The Ledger Card -->
  <div
    id="vip-ledger"
    class="absolute inset-0 flex items-center justify-center p-4 transition-opacity duration-300 ease-in-out"
  >
    <div class="bg-[#0a0a0a] border border-[#B829EA] w-[90vw] md:w-[30vw] lg:w-[22vw] p-8">
      <div class="text-center mb-8">
        <p class="text-[#DE005F] text-[0.6rem] tracking-[0.3em] font-bold uppercase">Restricted Access</p>
        <h3 class="text-white text-[1.25rem] font-bold mt-1 tracking-tight">Backstage Ledger</h3>
        <p class="text-zinc-500 text-[0.7rem] mt-2">Sign the ledger to enter the syndicate.</p>
      </div>

      <div class="space-y-6">
        <div>
          <label class="block text-zinc-500 text-[0.6rem] tracking-[0.2em] uppercase mb-2">Alias</label>
          <input
            id="vip-alias"
            type="text"
            placeholder="Your codename"
            autocomplete="off"
            class="w-full bg-transparent border-0 border-b-2 border-zinc-700 text-white text-[0.85rem] pb-2 outline-none focus:border-[#DE005F] transition-colors placeholder:text-zinc-600 rounded-none"
          />
        </div>
        <div>
          <label class="block text-zinc-500 text-[0.6rem] tracking-[0.2em] uppercase mb-2">Affiliation</label>
          <input
            id="vip-affiliation"
            type="text"
            placeholder="Your crew"
            autocomplete="off"
            class="w-full bg-transparent border-0 border-b-2 border-zinc-700 text-white text-[0.85rem] pb-2 outline-none focus:border-[#DE005F] transition-colors placeholder:text-zinc-600 rounded-none"
          />
        </div>
      </div>

      <button
        id="vip-submit"
        class="w-full mt-8 py-3 bg-[#DE005F] text-white text-[0.75rem] tracking-[0.15em] font-bold uppercase transition-all duration-200 hover:brightness-110 hover:shadow-[0_0_20px_rgba(222,0,95,0.4)]"
      >
        [ SLIP PAST SECURITY ]
      </button>

      <button
        id="vip-close"
        class="w-full mt-3 py-2 text-zinc-500 text-[0.65rem] tracking-[0.15em] uppercase transition-colors duration-200 hover:text-white"
      >
        [ SNEAK BACK TO CROWD ]
      </button>
    </div>
  </div>

  <!-- Layer 3: The Artifact Container -->
  <div
    id="vip-artifact"
    class="absolute inset-0 flex flex-col items-center justify-center p-4 hidden opacity-0 transition-opacity duration-300 ease-in-out"
  >
    <style>
      @keyframes vipGlowRotate {
        0% {
          box-shadow: 
            0 0 30px rgba(222, 0, 95, 0.4),
            0 0 60px rgba(184, 41, 234, 0.2);
        }
        25% {
          box-shadow: 
            inset 0 0 20px rgba(222, 0, 95, 0.1),
            0 0 40px rgba(222, 0, 95, 0.5),
            0 0 80px rgba(184, 41, 234, 0.3);
        }
        50% {
          box-shadow: 
            0 0 30px rgba(184, 41, 234, 0.4),
            0 0 60px rgba(222, 0, 95, 0.2);
        }
        75% {
          box-shadow: 
            inset 0 0 20px rgba(184, 41, 234, 0.1),
            0 0 40px rgba(184, 41, 234, 0.5),
            0 0 80px rgba(222, 0, 95, 0.3);
        }
        100% {
          box-shadow: 
            0 0 30px rgba(222, 0, 95, 0.4),
            0 0 60px rgba(184, 41, 234, 0.2);
        }
      }
      #ticket {
        animation: vipGlowRotate 4s ease-in-out infinite;
      }
    </style>
    <!-- Ticket Wrapper (perspective parent) -->
    <div id="ticket-wrapper" style="perspective: 60rem;" class="w-[90vw] md:w-[30vw] lg:w-[22vw]">
      <!-- Ticket (3D element) -->
      <div
        id="ticket"
        style="transform-style: preserve-3d;"
        class="relative bg-[#0a0a0a] border-2 border-[#DE005F] p-8 overflow-hidden select-none transition-transform duration-300 ease-out"
      >
        <!-- Glare overlay -->
        <div
          id="ticket-glare"
          class="pointer-events-none mix-blend-screen absolute inset-0 opacity-0 transition-opacity duration-300"
          style="background: radial-gradient(circle at 50% 50%, rgba(255,255,255,0.5) 0%, rgba(222,0,95,0.2) 30%, transparent 60%); background-size: 300% 300%; background-position: 50% 50%;"
        ></div>

        <!-- Ticket content -->
        <div class="relative z-10">
          <div class="text-center mb-6">
            <p class="text-[#DE005F] text-[0.5rem] tracking-[0.3em] font-bold uppercase">VIP Access</p>
            <div class="w-8 h-[1px] bg-[#DE005F] mx-auto my-3"></div>
            <h3 class="text-white text-[1rem] font-bold tracking-tight">BACKSTAGE SYNDICATE</h3>
          </div>

          <div class="border-t border-b border-zinc-800 py-4 my-4 space-y-3">
            <div class="flex justify-between items-center">
              <span class="text-zinc-500 text-[0.55rem] tracking-[0.2em] uppercase">Alias</span>
              <span id="ticket-alias" class="text-white text-[0.85rem] font-bold text-right">---</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-zinc-500 text-[0.55rem] tracking-[0.2em] uppercase">Affiliation</span>
              <span id="ticket-affiliation" class="text-white text-[0.85rem] font-bold text-right">---</span>
            </div>
          </div>

          <div class="text-center mt-4">
            <p class="text-[#DE005F] text-[0.5rem] tracking-[0.3em] font-bold">✦ │ DISHA '26 │ ✦</p>
            <p class="text-zinc-600 text-[0.45rem] tracking-[0.3em] uppercase mt-1">CET College Union</p>
          </div>
        </div>
      </div>
    </div>

    <button
      id="vip-extract"
      class="mt-6 py-3 px-8 bg-transparent border border-[#DE005F] text-[#DE005F] text-[0.7rem] tracking-[0.15em] font-bold uppercase transition-all duration-200 hover:bg-[#DE005F] hover:text-white hover:shadow-[0_0_20px_rgba(222,0,95,0.3)]"
    >
      [ EXTRACT & SHARE ]
    </button>

    <button
      id="vip-close2"
      class="mt-3 py-2 text-zinc-500 text-[0.6rem] tracking-[0.15em] uppercase transition-colors duration-200 hover:text-white hover:brightness-125"
    >
      [ SNEAK BACK TO CROWD ]
    </button>
  </div>
</div>

<script>
  (function () {
    var wrapper = document.getElementById('vip-wrapper');
    if (!wrapper) return;

    var backdrop = document.getElementById('vip-backdrop');
    var dim = document.getElementById('vip-dim');
    var ledger = document.getElementById('vip-ledger');
    var artifact = document.getElementById('vip-artifact');
    var aliasInput = document.getElementById('vip-alias');
    var affiliationInput = document.getElementById('vip-affiliation');
    var submitBtn = document.getElementById('vip-submit');
    var closeBtn = document.getElementById('vip-close');
    var closeBtn2 = document.getElementById('vip-close2');
    var ticketAlias = document.getElementById('ticket-alias');
    var ticketAffiliation = document.getElementById('ticket-affiliation');
    var ticket = document.getElementById('ticket');
    var glare = document.getElementById('ticket-glare');
    var extractBtn = document.getElementById('vip-extract');

    // Particle backdrop
    var bgCanvas = document.getElementById('vip-canvas');
    var bgCtx = bgCanvas ? bgCanvas.getContext('2d') : null;
    var bgParticles = [];
    var bgAnimId = null;
    var bgResizeId = null;
    var bgPalette = [
      'rgba(222, 0, 95, 1)',
      'rgba(184, 41, 234, 1)',
      'rgba(137, 17, 179, 1)',
      'rgba(222, 0, 95, 1)',
      'rgba(184, 41, 234, 1)',
      'rgba(255, 255, 255, 1)'
    ];

    function bgInit(w, h) {
      bgParticles = [];
      for (var i = 0; i < 10; i++) {
        bgParticles.push({
          x: Math.random() * w,
          y: Math.random() * h,
          vx: (Math.random() - 0.5) * 0.4,
          vy: (Math.random() - 0.5) * 0.4,
          r: 40 + Math.random() * 60,
          ci: i % bgPalette.length,
          a: 0.25 + Math.random() * 0.25,
          phase: Math.random() * Math.PI * 2
        });
      }
    }

    function bgResize() {
      if (!bgCanvas || !bgCtx) return;
      var w = bgCanvas.offsetWidth;
      var h = bgCanvas.offsetHeight;
      if (w === 0 || h === 0) return;
      var dpr = window.devicePixelRatio || 1;
      bgCanvas.width = w * dpr;
      bgCanvas.height = h * dpr;
      bgCtx.setTransform(dpr, 0, 0, dpr, 0, 0);
      if (bgParticles.length === 0) bgInit(w, h);
    }

    function bgDraw() {
      if (!bgCtx || !bgCanvas) return;
      var w = bgCanvas.offsetWidth;
      var h = bgCanvas.offsetHeight;
      if (w === 0 || h === 0) { bgAnimId = requestAnimationFrame(bgDraw); return; }

      bgCtx.clearRect(0, 0, w, h);

      var i, j, p, q, dx, dy, dist, grad, alpha;

      for (i = 0; i < bgParticles.length; i++) {
        p = bgParticles[i];
        p.x += p.vx;
        p.y += p.vy;
        if (p.x < -80 || p.x > w + 80) p.vx *= -1;
        if (p.y < -80 || p.y > h + 80) p.vy *= -1;
        p.x = Math.max(-80, Math.min(p.x, w + 80));
        p.y = Math.max(-80, Math.min(p.y, h + 80));
      }

      for (i = 0; i < bgParticles.length; i++) {
        for (j = i + 1; j < bgParticles.length; j++) {
          p = bgParticles[i];
          q = bgParticles[j];
          dx = p.x - q.x;
          dy = p.y - q.y;
          dist = Math.sqrt(dx * dx + dy * dy);
          if (dist < 300) {
            alpha = (1 - dist / 300) * 0.2;
            grad = bgCtx.createLinearGradient(p.x, p.y, q.x, q.y);
            grad.addColorStop(0, bgPalette[p.ci].replace('1)', (p.a * alpha) + ')'));
            grad.addColorStop(0.5, 'rgba(137, 17, 179, ' + (alpha * 0.5) + ')');
            grad.addColorStop(1, bgPalette[q.ci].replace('1)', (q.a * alpha) + ')'));
            bgCtx.strokeStyle = grad;
            bgCtx.lineWidth = 1.5;
            bgCtx.beginPath();
            bgCtx.moveTo(p.x, p.y);
            bgCtx.lineTo(q.x, q.y);
            bgCtx.stroke();
          }
        }
      }

      for (i = 0; i < bgParticles.length; i++) {
        p = bgParticles[i];
        grad = bgCtx.createRadialGradient(p.x, p.y, 0, p.x, p.y, p.r);
        grad.addColorStop(0, 'rgba(255, 255, 255, ' + (p.a * 0.5) + ')');
        grad.addColorStop(0.25, bgPalette[p.ci].replace('1)', (p.a * 0.4) + ')'));
        grad.addColorStop(0.6, bgPalette[p.ci].replace('1)', (p.a * 0.1) + ')'));
        grad.addColorStop(1, 'transparent');
        bgCtx.fillStyle = grad;
        bgCtx.beginPath();
        bgCtx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
        bgCtx.fill();
      }

      bgAnimId = requestAnimationFrame(bgDraw);
    }

    var bgResizeHandler = null;

    function bgStart() {
      if (!bgCanvas || !bgCtx) return;
      bgResize();
      if (bgAnimId) cancelAnimationFrame(bgAnimId);
      bgDraw();
      if (!bgResizeHandler) {
        bgResizeHandler = bgResize;
        window.addEventListener('resize', bgResizeHandler);
      }
    }

    function bgStop() {
      if (bgAnimId) { cancelAnimationFrame(bgAnimId); bgAnimId = null; }
      if (bgCtx && bgCanvas) bgCtx.clearRect(0, 0, bgCanvas.offsetWidth, bgCanvas.offsetHeight);
      bgParticles = [];
      if (bgResizeHandler) {
        window.removeEventListener('resize', bgResizeHandler);
        bgResizeHandler = null;
      }
    }

    var freezeStyle = null;
    function freezePage() {
      document.body.classList.add('vip-freeze');
      if (!freezeStyle) {
        freezeStyle = document.createElement('style');
        freezeStyle.id = 'vip-freeze-style';
        freezeStyle.textContent = 'body.vip-freeze #page-freeze-zone, body.vip-freeze #page-freeze-zone * { animation-play-state: paused !important; transition-duration: 999999s !important; }';
        document.head.appendChild(freezeStyle);
      }
    }
    function unfreezePage() {
      document.body.classList.remove('vip-freeze');
      if (freezeStyle) { freezeStyle.remove(); freezeStyle = null; }
    }

    function openModal() {
      freezePage();
      document.body.style.overflow = 'hidden';
      wrapper.classList.remove('hidden');
      void wrapper.offsetHeight;
      wrapper.classList.remove('opacity-0');
      bgStart();

      dim.style.opacity = '0';
      ledger.classList.remove('opacity-0', 'hidden');
      artifact.classList.add('opacity-0', 'hidden');
      aliasInput.value = '';
      affiliationInput.value = '';
      extractBtn.textContent = '[ EXTRACT & SHARE ]';
      extractBtn.style.pointerEvents = 'auto';
    }

    function closeModal() {
      unfreezePage();
      bgStop();
      wrapper.classList.add('opacity-0');
      document.body.style.overflow = '';
      dim.style.opacity = '0';
      setTimeout(function () {
        wrapper.classList.add('hidden');
        ledger.classList.remove('opacity-0', 'hidden');
        artifact.classList.add('opacity-0', 'hidden');
      }, 500);
    }

    window.addEventListener('trigger-vip-egg', openModal);

    backdrop.addEventListener('click', closeModal);
    closeBtn.addEventListener('click', closeModal);
    closeBtn2.addEventListener('click', closeModal);

    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && wrapper.classList.contains('hidden') === false) {
        closeModal();
      }
    });

    submitBtn.addEventListener('click', function () {
      var alias = aliasInput.value.trim() || 'Ghost';
      var affiliation = affiliationInput.value.trim() || 'Unaffiliated';
      ticketAlias.textContent = alias;
      ticketAffiliation.textContent = affiliation;

      dim.style.opacity = '0.85';
      ledger.classList.add('opacity-0');
      setTimeout(function () {
        ledger.classList.add('hidden');
        artifact.classList.remove('hidden');
        void artifact.offsetHeight;
        artifact.classList.remove('opacity-0');
      }, 300);
    });

    // Tilt physics
    var tiltFrameId = null;
    var rotX = 0;
    var rotY = 0;

    if (ticket) {
      ticket.addEventListener('pointermove', function (e) {
        var rect = ticket.getBoundingClientRect();
        var centerX = rect.left + rect.width / 2;
        var centerY = rect.top + rect.height / 2;
        var pX = (e.clientX - centerX) / (rect.width / 2);
        var pY = (e.clientY - centerY) / (rect.height / 2);
        rotY = pX * 15;
        rotX = -pY * 15;

        if (glare) {
          var gX = ((e.clientX - rect.left) / rect.width) * 100;
          var gY = ((e.clientY - rect.top) / rect.height) * 100;
          glare.style.backgroundPosition = gX + '% ' + gY + '%';
          glare.style.opacity = '0.4';
        }

        if (!tiltFrameId) {
          tiltFrameId = requestAnimationFrame(function () {
            ticket.style.transform = 'rotateX(' + rotX + 'deg) rotateY(' + rotY + 'deg)';
            tiltFrameId = null;
          });
        }
      });

      ticket.addEventListener('pointerleave', function () {
        if (tiltFrameId) {
          cancelAnimationFrame(tiltFrameId);
          tiltFrameId = null;
        }
        ticket.style.transform = 'rotateX(0deg) rotateY(0deg)';
        if (glare) {
          glare.style.opacity = '0';
        }
      });
    }

    // Capture & native share
    extractBtn.addEventListener('click', async function () {
      extractBtn.textContent = '[ PROCESSING... ]';
      extractBtn.style.pointerEvents = 'none';

      // Flatten 3D transforms so html2canvas renders properly
      var savedTransform = ticket.style.transform;
      var savedTransformStyle = ticket.style.transformStyle;
      ticket.style.transform = 'none';
      ticket.style.transformStyle = 'flat';

      var captureBlob = null;
      var wasAnimating = !!bgAnimId;
      if (bgAnimId) {
        cancelAnimationFrame(bgAnimId);
        bgAnimId = null;
      }

      function isMobileDevice() {
        return (
          navigator.maxTouchPoints > 2 || 
          /android|webos|iphone|ipad|ipod|blackberry|iemobile|opera mini/i.test(navigator.userAgent.toLowerCase())
        );
      }
      var isMobile = isMobileDevice();

      try {
        var htmlMod = await import('html-to-image');
        var blob = await htmlMod.toBlob(ticket, {
          backgroundColor: '#050505',
          pixelRatio: isMobile ? 1.5 : 2.5,
          fontEmbedCSS: '', // Skip fetching external CSS fonts which avoids the CORS CSSStyleSheet error
          skipFonts: true   // Skip font embedding completely to avoid the SecurityError on Google Fonts
        });

        if (!blob) {
          console.error('Capture failed: blob not created');
          return;
        }

        console.log('Capture successful:', blob.size, 'bytes');

        var file = new File([blob], 'Disha26VIP_Pass.png', { type: 'image/png' });
        var canShare = navigator.canShare && navigator.canShare({ files: [file] });

        if (isMobile && canShare) {
          try {
            await navigator.share({
              files: [file],
              title: "Disha '26",
              text: "Here's my Disha 2026 VIP Pass, where's yours?"
            });
            console.log('Easter Egg shared successfully');
          } catch (error) {
            if (error.name !== 'AbortError') {
              console.error('Share failed:', error.message);
            }
          }
        } else {
          try {
            var url = URL.createObjectURL(blob);
            var a = document.createElement('a');
            a.href = url;
            a.download = 'Disha26VIP_Pass.png';
            document.body.appendChild(a);
            a.click();
            console.log('Easter Egg downloaded successfully');
            
            setTimeout(function () {
              document.body.removeChild(a);
              URL.revokeObjectURL(url);
            }, 5000);
          } catch (error) {
            console.error('Download failed:', error.message);
          }
        }
      } catch (error) {
        console.error('Easter Egg capture failed:', error.message, error.stack);
      } finally {
        ticket.style.transform = savedTransform;
        ticket.style.transformStyle = savedTransformStyle;

        if (wasAnimating) {
          bgStart();
        }

        extractBtn.textContent = '[ EXTRACT & SHARE ]';
        extractBtn.style.pointerEvents = 'auto';
      }
    });
  })();
</script>
