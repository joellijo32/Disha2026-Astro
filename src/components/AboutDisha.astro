---
import { Image } from 'astro:assets';
import kalyaniforwebAsset from '../assets/kalyaniFORweb.webp';
const ABOUT_TEXT = "DISHA is CET's biggest freshers' event, with an immense participation count from freshers over 8 departments. Being one of three iconic D's of CET, DISHA provides a dynamic platform for freshers to showcase their artistic talents and cultivate a high-energy synergy within the campus. Departments compete with each other ultimately for the glorious DISHA Cup. DISHA'26 will be packed with events, excitement and moments freshers will never forget.";
const words = ABOUT_TEXT.split(' ');
---

<section id="about" class="relative min-h-screen bg-[#000000] py-24 md:py-32 overflow-hidden">
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-[#DE005F]/15 via-[#10152B]/90 to-[#000000] z-0 opacity-50"></div>

  <div class="absolute top-0 right-0 w-[70%] md:w-[40%] h-[50%] bg-[radial-gradient(#DE005F_1px,transparent_1px)] [background-size:16px_16px] [mask-image:radial-gradient(ellipse_at_top_right,black_10%,transparent_90%)] z-[5] opacity-50 pointer-events-none"></div>

  <div class="absolute bottom-0 left-0 w-[70%] md:w-[40%] h-[50%] bg-[radial-gradient(#B829EA_1px,transparent_1px)] [background-size:16px_16px] [mask-image:radial-gradient(ellipse_at_bottom_left,black_10%,transparent_90%)] z-[5] opacity-50 pointer-events-none"></div>

  <div class="absolute bottom-0 left-0 w-[70%] md:w-[40%] h-[50%] bg-[radial-gradient(circle,#B829EA_1px,transparent_1px)] bg-[size:16px_16px] [mask-image:radial-gradient(ellipse_at_bottom_left,black_10%,transparent_90%)] z-30 opacity-50 pointer-events-none"></div>


  <div class="relative z-10 max-w-7xl mx-auto px-6 flex flex-col lg:flex-row items-center justify-center lg:gap-24">

    <div class="w-full flex flex-col items-center text-center lg:hidden mb-12">
      <span class="text-white text-4xl md:text-6xl font-black uppercase tracking-widest leading-none font-bohme reveal-on-scroll">
        ABOUT
      </span>
      <span class="relative -mt-4 md:-mt-8 text-[#cc007c] font-['Sedgwick_Ave_Display',_cursive] font-extrabold tracking-wider text-7xl md:text-9xl reveal-on-scroll [text-shadow:0_0_15px_#cc007c]" style="z-index: 2;">
        DISHA
      </span>
    </div>

    <div class="w-full lg:w-1/2 flex items-center justify-center lg:justify-end mb-28 md:mb-40 lg:mb-0 lg:-ml-28 lg:pb-40">
      <div class="relative inline-block scale-[1.3] lg:scale-125 origin-center">
        <Image
          src={kalyaniforwebAsset}
          alt="Illustrated version of the Kalyani character"
          width={2400}
          height={1428}
          widths={[400, 800, 1200]}
          sizes="(max-width: 1024px) 100vw, 50vw"
          loading="lazy"
          decoding="async"
          class="w-full h-auto object-cover max-w-4xl lg:max-w-[70rem] xl:max-w-[80rem] kalyaniforweb-reveal"
        />
        <span class="inline-block absolute bottom-0 left-1/2 -translate-x-1/2 translate-y-1/2 lg:translate-y-2/5 text-[#cc007c] font-['Sedgwick_Ave_Display',_cursive] text-[min(12vw,4rem)] md:text-[min(14vw,7rem)] lg:text-[8rem] font-extrabold tracking-[-0.05em] [-webkit-text-stroke:1px_#fff] drop-shadow-[0_0_10px_rgba(204,0,124,0.3),0_0_25px_rgba(204,0,124,0.15)] z-20 reveal-on-scroll whitespace-nowrap text-center glow-kalyani">
          Kalyani
        </span>
      </div>
    </div>

    <div class="w-full lg:w-1/2 flex flex-col items-center lg:items-start text-center lg:text-left text-white relative">
      <div class="w-full max-w-2xl lg:max-w-none">
        <div class="hidden lg:flex flex-col items-center lg:items-start mb-8 md:mb-16">
          <span class="text-white text-4xl md:text-6xl font-black uppercase tracking-widest leading-none font-bohme reveal-on-scroll">
            ABOUT
          </span>
          <span class="relative -mt-4 md:-mt-8 text-[#cc007c] font-['Sedgwick_Ave_Display',_cursive] font-extrabold tracking-wider text-7xl md:text-9xl reveal-on-scroll [text-shadow:0_0_15px_#cc007c]" style="z-index: 2;">
            DISHA
          </span>
        </div>
        <div class="relative">
          <div class="absolute inset-0 flex items-center justify-center pointer-events-none select-none" style="z-index: 0;">
            <p class="text-[12rem] md:text-[18rem] lg:text-[22rem] tracking-widest font-black uppercase text-gray-700 opacity-10">KALYANI</p>
          </div>
          <p class="text-lg md:text-xl font-bold leading-loose tracking-[0.15em] relative z-10 flex flex-wrap font-myriad">
            {words.map((word, i) => (
              <span key={i} class="reveal-word mr-[0.35em]" style="color:rgba(255,255,255,0.2)">{word}</span>
            ))}
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .reveal-on-scroll {
    opacity: 0;
    transition: opacity 0.8s ease;
  }
  .reveal-on-scroll.visible {
    opacity: 1;
  }
  .kalyaniforweb-reveal {
    opacity: 0;
    transform: scale(0.9);
    transition: opacity 0.8s ease, transform 0.8s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .kalyaniforweb-reveal.visible {
    opacity: 1;
    transform: scale(1);
  }
  .glow-kalyani::before {
    content: 'Kalyani';
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    color: transparent;
    filter: blur(10px);
    -webkit-text-stroke: 4px rgba(204,0,124,0.25);
    z-index: -1;
  }
</style>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
        } else {
          entry.target.classList.remove('visible');
        }
      });
    },
    { threshold: 0.2 }
  );

  document.querySelectorAll('.reveal-on-scroll').forEach((el) => observer.observe(el));

  const kalyaniforwebEl = document.querySelector('.kalyaniforweb-reveal');
  if (kalyaniforwebEl) observer.observe(kalyaniforwebEl);

  // Word-by-word reveal with ScrollTrigger-like behavior
  const wordEls = document.querySelectorAll('.reveal-word');
  const wordObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          wordEls.forEach((el, i) => {
            setTimeout(() => {
              el.style.color = 'rgba(255,255,255,1)';
              el.style.transition = 'color 0.3s ease';
            }, i * 50);
          });
        } else {
          wordEls.forEach((el) => {
            el.style.color = 'rgba(255,255,255,0.2)';
          });
        }
      });
    },
    { threshold: 0.3 }
  );

  if (wordEls.length > 0) {
    const parent = wordEls[0].parentElement;
    if (parent) wordObserver.observe(parent);
  }
</script>
